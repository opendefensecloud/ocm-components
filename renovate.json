{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>opendefensecloud/renovate-config"
  ],
  "customManagers": [
    {
      "customType": "jsonata",
      "fileFormat": "yaml",
      "managerFilePatterns": ["/.*/component-constructor.yaml$/"],
      "matchStrings": [
        "components.resources[type = 'ociImage'].{'depName': $split(access.imageReference, ':')[0], 'currentValue': $split(access.imageReference, ':')[1]}",
        "components.resources[type = 'ociImage'].{'depName': $split(access.imageReference, ':')[0], 'currentValue': version}"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "matchStringsStrategy": "any",
      "managerFilePatterns": ["/.*/component-constructor.yaml$/"],
      "matchStrings": [
        "helmChart: (?<depName>.*):(?<currentValue>.*)\\s*helmRepository: (?<registryUrl>.*)",
        "helmChart: (?<depName>.*)\\s*helmRepository: (?<registryUrl>.*)\\s*type: helm\\s*version: (?<currentValue>.*)"
      ],
      "datasourceTemplate": "helm"
    }
  ]
}
