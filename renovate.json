{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "jsonata",
      "fileFormat": "yaml",
      "managerFilePatterns": ["/.*/component-constructor.yaml$/"],
      "matchStrings": [
        "components.resources[type = 'ociImage'].{'depName': $split(access.imageReference, ':')[0], 'currentValue': $split(access.imageReference, ':')[1]}",
        "components.resources[type = 'ociImage'].{'depName': $split(access.imageReference, ':')[0], 'currentValue': version}"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "jsonata",
      "fileFormat": "yaml",
      "managerFilePatterns": ["/.*/component-constructor.yaml$/"],
      "matchStrings": [
        "components.resources[type = 'helmChart'].{'depName': $split(access.helmChart, ':')[0], 'currentValue': $split(access.helmChart, ':')[1], 'registryUrl': access.helmRepository}",
        "components.resources[type = 'helmChart'].{'depName': $split(access.helmChart, ':')[0], 'currentValue': version, 'registryUrl': access.helmRepository}"
      ],
      "datasourceTemplate": "helm",
      "extractVersion": "^v?(?<version>.*)$"
    }
  ]
}
